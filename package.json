{
  "name": "litedrop",
  "version": "0.0.0",
  "private": true,
  "description": "Share markdown/HTML via a link. CLI-first. (npm-workspaces monorepo)",
  "workspaces": [
    "packages/*",
    "apps/*",
    "cli"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "openapi:check": "npm run openapi:check --workspaces --if-present",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
