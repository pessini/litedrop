{
  "name": "@litedrop/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reusable litedrop core library for hosted and self-hosted runtimes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pessini/litedrop.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.24",
    "markdown-it": "^14.2.0",
    "sanitize-html": "^2.17.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^6.0.3"
  }
}
