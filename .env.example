# --- litedrop config (12-factor; validated by apps/backend/src/env.ts) ---

# Runtime
NODE_ENV=development
PORT=8080

# SQLite database location: a file: URL (default) or :memory: for throwaway
# runs. Migrated automatically at boot — zero external services.
DATABASE_URL=file:./.data/litedrop.db

# Public base URL of the app/dashboard origin.
APP_BASE_URL=http://localhost:8080

# Public base URL used to build share links. Blank → falls back to APP_BASE_URL.
# Set this to a dedicated share hostname for split-host deployments.
PUBLIC_SHARE_BASE_URL=

# Trust reverse-proxy client IP headers for rate limits. Leave false when
# running the backend directly; set true only behind a proxy that overwrites
# X-Forwarded-For / CF-Connecting-IP from untrusted clients.
TRUST_PROXY_HEADERS=false

# --- Auth (single-user; no accounts, no signup) ---

# Dashboard login password (≥8 chars). The login form posts it and receives a
# signed session cookie. Leave blank to run headless (CLI/API only).
ADMIN_PASSWORD=

# Bearer token the CLI/agents send (Authorization: Bearer <LITEDROP_TOKEN>),
# ≥16 chars. Rotate by changing it. Blank = no token auth (dashboard only).
#   openssl rand -hex 32
LITEDROP_TOKEN=

# Dashboard login cookie lifetime, in days.
SESSION_TTL_DAYS=30

# Secret signing the session cookie, the slug-scoped share-password cookie, and
# the content token. Blank = generated on first boot and persisted to
# DATA_DIR/unlock-secret (zero-config). Set explicitly (≥16 chars) on read-only
# filesystems:  openssl rand -hex 32
UNLOCK_COOKIE_SECRET=

# Directory for small server-managed state (the generated signing secret; the
# default SQLite database lives here too).
DATA_DIR=./.data

# --- Content isolation ---

# Base URL of the ISOLATED user-content origin that serves raw user HTML into
# the sandboxed iframe. In production set it to a separate registrable domain
# from APP_BASE_URL (so a sandbox escape can't reach the session cookie) and
# route it to the same app. Blank in dev → falls back to APP_BASE_URL
# (single-origin, NOT isolated; a warning is logged at boot).
CONTENT_BASE_URL=

# Opt out of the production CONTENT_BASE_URL requirement so you only need ONE
# hostname. The iframe stays sandboxed (opaque-origin); this only drops the
# separate-domain layer. Leave false when CONTENT_BASE_URL is set.
ALLOW_SAME_ORIGIN_CONTENT=false

# --- Storage ---
# Provider: one of
#   local → filesystem (default)
#   s3    → AWS S3 or any S3-compatible service (MinIO, Backblaze B2, Spaces, …)
#   r2    → Cloudflare R2 (S3 API)
#   azure → Azure Blob Storage
# Only the selected provider's vars are required; the app exits at boot if any
# are missing. STORAGE_DIR is the local-disk root.
STORAGE_PROVIDER=local
STORAGE_DIR=./.storage

# r2 — Cloudflare R2 (S3 API). R2_ENDPOINT overrides the account endpoint.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# s3 — AWS S3 or any S3-compatible service. For AWS just set S3_REGION +
# S3_BUCKET (+ keys); for others set S3_ENDPOINT (path-style). Keys fall back to
# AWS_* if unset.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# azure — Azure Blob Storage (Shared Key auth). AZURE_BLOB_ENDPOINT overrides
# the default <account>.blob.core.windows.net (e.g. for the Azurite emulator).
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=
AZURE_BLOB_ENDPOINT=

# --- Storage cleanup sweep ---
# Objects of shares revoked/expired/consumed for longer than the grace period
# are deleted (the row is kept). Runs at boot and every interval; 0 disables.
CLEANUP_GRACE_DAYS=7
CLEANUP_INTERVAL_MINUTES=60
