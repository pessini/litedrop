# deploy/.env — config for the production docker-compose (app + Caddy).

# Your app's hostname. Point an A/AAAA record at this server first; Caddy
# fetches the TLS certificate automatically.
DOMAIN=drop.example.com

# Hostname of the isolated origin that renders user-uploaded HTML (a second
# DNS record to the same server). Defaults to content.$DOMAIN if unset.
#CONTENT_DOMAIN=content.drop.example.com

# Dashboard password for this instance's single admin account (≥8 chars).
ADMIN_PASSWORD=change-me-please

# Bearer token the CLI/agents send (Authorization: Bearer …), ≥16 chars.
# Blank = no token auth (dashboard only).
#   openssl rand -hex 32
LITEDROP_TOKEN=
